# ============================================================================
# answers.env — operator inputs for install.sh
# ============================================================================
# Copy to answers.env (git-ignored) and fill in. Only DOMAIN is required.
# Everything under "generated automatically" is created + persisted for you by
# bootstrap_secrets.py — leave those out. The bring-your-own keys are optional:
# any you omit simply leave that integration disabled (the app still deploys).
#
#   cp answers.env.example answers.env && $EDITOR answers.env
#   sudo ./install.sh            # reads answers.env from the current directory
# ============================================================================

# ──────────────── Required ────────────────
DOMAIN=example.com

# ──────────────── Optional: Dokploy admin ────────────────
# Omit to auto-generate a strong password (stored in /etc/dokploy-ai/secrets.env).
# DOKPLOY_ADMIN_EMAIL=admin@example.com
# DOKPLOY_ADMIN_PASSWORD=

# ──────────────── Cloudflare Tunnel ingress (only when --ingress tunnel) ────────────────
# Use this when the box has NO public inbound (home server / NAT). A Cloudflare
# Tunnel dials out to Cloudflare's edge and fronts every app at
# https://<app>.$DOMAIN with free edge TLS — no port-forwarding, no public A
# record. install.sh reads these from answers.env / the environment.
#
# Create an API token at https://dash.cloudflare.com/profile/api-tokens with:
#     Account > Cloudflare Tunnel > Edit
#     Zone    > DNS  > Edit
#     Zone    > Zone > Read
# Run with:  sudo ./install.sh --domain $DOMAIN --ingress tunnel
#
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# Optional — the named tunnel to create/reuse (default: devhub)
# CLOUDFLARE_TUNNEL_NAME=devhub
# Optional — Dokploy dashboard basic-auth gate (dokploy.$DOMAIN). Defaults to
# user 'admin' and the Dokploy admin password if left unset.
# DOKPLOY_GATE_USER=
# DOKPLOY_GATE_PASSWORD=

# ──────────────── Generated automatically — do NOT set ────────────────
# POSTGRES_PASSWORD, N8N_ENCRYPTION_KEY, N8N_*_PASSWORD, OPEN_WEBUI_ADMIN_PASSWORD,
# DEV_HUB_* , FLASK_SECRET_KEY, DB_PASSWORD, GUACAMOLE_SECRET_KEY, SUPERADMIN_PASSWORD,
# OPENCLAW_GATEWAY_TOKEN, IDP_* — all created + reused across runs.

# ──────────────── Bring-your-own (optional external integrations) ────────────────
# CP Agentic MCP Playground — Check Point / LLM integrations
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# LAKERA_API_KEY=
# IDP_SCIM_TOKEN=
# Azure OpenAI is the default model behind every n8n agent — supply all three
# (key + endpoint + deployment) or the Azure node stays unconfigured.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_CONTENT_SAFETY_KEY=
# AZURE_CONTENT_SAFETY_ENDPOINT=
# MANAGEMENT_HOST=
# MANAGEMENT_API_KEY=
# SMS_API_KEY=
# TE_API_KEY=
# REPUTATION_API_KEY=
# SPARK_MGMT_CLIENT_ID=
# SPARK_MGMT_SECRET_KEY=
# SPARK_MGMT_REGION=
# SPARK_MGMT_INFINITY_PORTAL_URL=
# HARMONY_SASE_API_KEY=
# HARMONY_SASE_MANAGEMENT_HOST=
# HARMONY_SASE_REGION=
# DOC_CLIENT_ID=
# DOC_SECRET_KEY=
# DOC_REGION=
# IPS MCP (Infinity Portal IPS service)
# IPS_CLIENT_ID=
# IPS_ACCESS_KEY=
# IPS_AUTH_URL=
# IPS_SERVICE_URL=
# Optional docker-compose service profile(s). Default is cpu; add security-lab to
# turn on the security-lab services (e.g. COMPOSE_PROFILES=cpu,security-lab).
# COMPOSE_PROFILES=cpu,security-lab

# AI Guardrails Demo — Lakera Guard credentials (platform.lakera.ai)
# DEMO_API_KEY=
# DEMO_PROJECT_ID=

# Training Portal — vSphere creds for hands-on lab-VM provisioning + Guacamole
# consoles. Without these the portal keeps the placeholder host and can't spin up
# lab VMs.
# VSPHERE_HOST=
# VSPHERE_USER=
# VSPHERE_PASSWORD=

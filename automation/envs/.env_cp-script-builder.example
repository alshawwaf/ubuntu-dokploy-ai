# ============================================================================
# CP Script Builder - Environment Configuration
# ============================================================================
# All three variables are REQUIRED for the app to boot. SECRET_KEY and
# APP_PASSWORD are generated by automation/bootstrap_secrets.py at install time
# (the placeholders below are replaced in the rendered .env_cp-script-builder);
# APP_USERNAME is derived from the deploy --domain.
#
# NOTE: cp-script-builder is a PRIVATE repo (git@github.com:...). Register this
# box's SSH public key as a deploy key on the repo first — see the README
# ("Private repositories / CP Script Builder") — or Dokploy cannot clone it.
# ============================================================================

# Flask session signing key [REQUIRED]
SECRET_KEY=generated-at-install

# Admin login [REQUIRED]
APP_USERNAME=admin@{{DOMAIN}}
APP_PASSWORD=generated-at-install

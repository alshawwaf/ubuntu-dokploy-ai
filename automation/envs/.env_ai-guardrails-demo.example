# ============================================================================
# AI Guardrails Demo - Environment Configuration
# ============================================================================
# Copy this file to .env_ai-guardrails-demo and fill in your values
# Get your AI Guardrails API key from https://platform.lakera.ai/
# ============================================================================

# ──────────────── AI Guardrails API [REQUIRED] ────────────────
DEMO_API_KEY=your-guardrails-guard-api-key
DEMO_PROJECT_ID=your-guardrails-project-id
DEMO_API_URL=https://api.lakera.ai/v2/guard

# ──────────────── OpenAI Configuration [OPTIONAL] ────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# ──────────────── Azure OpenAI Configuration [OPTIONAL] ────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ──────────────── Azure AI Content Safety [OPTIONAL] ────────────────
AZURE_CONTENT_SAFETY_KEY=your-content-safety-key
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# ──────────────── Google Gemini [OPTIONAL] ────────────────
GEMINI_API_KEY=your-gemini-api-key

# ──────────────── Ollama Configuration [OPTIONAL] ────────────────
# Ollama joins dokploy-network, so AI Guardrails reaches it by name (no host IP).
OLLAMA_API_URL=http://ollama-cpu:11434
# 300s: mythos-9b on CPU is slow to first token.
OLLAMA_TIMEOUT=300
# Uncensored "target LLM" — complies with jailbreaks when Guard is off, which
# is what makes Guard's block visible in the demo.
OLLAMA_MODEL=richardyoung/mythos-9b-unhinged-abliterated:latest

# ──────────────── Playground default LLM [OPTIONAL] ────────────────
# Pins what the playground opens with when a browser has no saved choice, so
# the demo works out of the box. A user's own selection still overrides. Must be a
# model the agentic OLLAMA_MODELS list actually pulls, or first load 404s.
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=gemma4:e2b

# ──────────────── Application Configuration ────────────────
APP_PORT=9000
LOGS_DIR=logs
LOG_FILENAME=application.log

# ──────────────── CORS Configuration ────────────────
# Comma-separated list of allowed origins, or "*" for all
CORS_ORIGINS=*

# ──────────────── Rate Limiting ────────────────
# Match the app's built-in 100000 default — the hub embed re-hits the demo enough
# that low caps (200/50) trip instantly and lock out the playground.
RATE_LIMIT_DAILY=100000
RATE_LIMIT_HOURLY=100000
# For production with Redis: redis://localhost:6379
RATE_LIMIT_STORAGE=memory://

# ──────────────── Production Server (Gunicorn) ────────────────
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=600
GUNICORN_BIND=0.0.0.0:9000

# ──────────────── Security Configuration ────────────────
DEFAULT_ADMIN_EMAIL=admin@{{DOMAIN}}
DEFAULT_ADMIN_PASSWORD=your-secure-admin-password
FLASK_SECRET_KEY=your-random-flask-secret-key

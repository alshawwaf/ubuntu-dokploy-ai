# ============================================================================
# OpenClaw - Environment Configuration
# ============================================================================
# Copy this file to .env_openclaw and fill in your values
# ============================================================================

# [REQUIRED] Auth token for the gateway — any strong random string
# All clients must enter this token to connect to your OpenClaw instance
OPENCLAW_GATEWAY_TOKEN=your-strong-random-token-here

# [REQUIRED] OpenAI API key used by the AI agent
OPENAI_API_KEY=sk-...

# [OPTIONAL] Timezone (default: UTC)
OPENCLAW_TZ=UTC

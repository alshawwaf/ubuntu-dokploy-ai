# ============================================================================
# Dev Hub - Environment Configuration
# ============================================================================
# Dev Hub deploys pure-git (composePath ./docker-compose.dokploy.yml in the
# dev-hub repo), so its compose reads every value via ${VAR} interpolation from
# this rendered .env — nothing is baked into the compose. bootstrap_secrets.py
# fills the generated secrets below (DEV_HUB_DB_PASSWORD / DEV_HUB_SECRET_KEY /
# DEV_HUB_SUPERADMIN_PASSWORD / DEVHUB_MCP_TOKEN); the automation replaces
# {{DOMAIN}} with the --domain argument.
# ============================================================================

# ──────────────── Domain ────────────────
DOMAIN={{DOMAIN}}
SUPERADMIN_EMAIL=admin@{{DOMAIN}}

# ──────────────── Runtime secrets (generated by bootstrap_secrets.py) ────────────────
DEV_HUB_DB_PASSWORD=
DEV_HUB_SECRET_KEY=
DEV_HUB_SUPERADMIN_PASSWORD=
DEVHUB_MCP_TOKEN=

# ──────────────── Frontend ────────────────
# The frontend defaults to the relative /api (nginx proxies same-origin), so
# VITE_API_URL is informational; the compose does not consume it.
VITE_API_URL=/api

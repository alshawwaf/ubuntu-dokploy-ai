# ============================================================================
# PolicyPilot - Environment Configuration
# ============================================================================
# Secrets (SESSION_SECRET, ENCRYPTION_KEY, ADMIN_PASSWORD) are generated by
# automation/bootstrap_secrets.py at install time — the placeholders below are
# replaced in the rendered .env_policypilot.
# ============================================================================

# External URL (Traefik terminates TLS on this host)
PILOT_BASE_URL=https://policypilot.{{DOMAIN}}

# Admin login
PILOT_ADMIN_USERNAME=admin@{{DOMAIN}}
PILOT_ADMIN_PASSWORD=generated-at-install

# Session signing + credential encryption (kept independent so rotating one
# never orphans the other)
PILOT_SESSION_SECRET=generated-at-install
PILOT_ENCRYPTION_KEY=generated-at-install

# Agent MCP bearer token. PolicyPilot seeds an mcp-scope API key from this on
# boot; the cp-agentic n8n agent authenticates with the identical value (the
# same PILOT_MCP_TOKEN is also rendered into .env_agentic).
PILOT_MCP_TOKEN=generated-at-install

# ============================================================================
# Drawbridge (Datacenter Simulator) - Environment Configuration
# ============================================================================
# Secrets (SESSION_SECRET, ENCRYPTION_KEY, ADMIN_PASSWORD) are generated by
# automation/bootstrap_secrets.py at install time — the placeholders below are
# replaced in the rendered .env_drawbridge.
# ============================================================================

# External URL (Traefik terminates TLS on this host)
DCSIM_BASE_URL=https://dcsim.{{DOMAIN}}

# Admin login
DCSIM_ADMIN_USERNAME=admin@{{DOMAIN}}
DCSIM_ADMIN_PASSWORD=generated-at-install

# Session signing + integration-secret encryption
DCSIM_SESSION_SECRET=generated-at-install
DCSIM_ENCRYPTION_KEY=generated-at-install

# SIEM receiver port (Check Point Log Exporter target); 0 disables.
# NOTE: the hardened host firewall blocks non-80/443 — `ufw allow 5514` if used.
DCSIM_SYSLOG_PORT=5514

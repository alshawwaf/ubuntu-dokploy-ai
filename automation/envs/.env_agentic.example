# ============================================================================
# CP Agentic MCP Playground - Environment Configuration
# ============================================================================
# Copy this file to .env_agentic and fill in your values
# Variables marked [REQUIRED] must be set, [OPTIONAL] have defaults
# ============================================================================

# ──────────────── PostgreSQL Database ────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=your-secure-db-password
POSTGRES_DB=n8n
POSTGRES_PORT=5432

# ──────────────── n8n Workflow Automation ────────────────
N8N_HOST=n8n.{{DOMAIN}}
N8N_PORT=5678
N8N_ENCRYPTION_KEY=your-long-random-encryption-key-here
N8N_USER_MANAGEMENT_JWT_SECRET=your-jwt-secret-key-here

# n8n Admin User [REQUIRED]
N8N_ADMIN_EMAIL=admin@{{DOMAIN}}
N8N_ADMIN_FIRST_NAME=Admin
N8N_ADMIN_LAST_NAME=User
N8N_ADMIN_PASSWORD=your-secure-admin-password

# n8n Basic Auth [REQUIRED]
N8N_BASIC_AUTH_USER=admin@{{DOMAIN}}
N8N_BASIC_AUTH_PASSWORD=your-secure-basic-auth-password

# ──────────────── Agent MCP bearer tokens ────────────────
# Shared secrets generated by bootstrap_secrets.py. The n8n agent-import
# container substitutes these into the two bearer credentials it creates so the
# PolicyPilot / dev-hub agents can call those MCP endpoints. The SAME values are
# seeded on the PolicyPilot (PILOT_MCP_TOKEN) and dev-hub (DEVHUB_MCP_TOKEN)
# sides, so the tokens match end-to-end.
PILOT_MCP_TOKEN=generated-at-install
DEVHUB_MCP_TOKEN=generated-at-install

# Bearer token the Docker MCP Gateway requires from clients; the n8n import
# substitutes it into the "CP MCP Gateway Bearer" credential used by the
# *-via-gateway agents. The default matches the gateway's training token.
MCP_GATEWAY_TOKEN=cp-mcp-gateway-training-token

# ──────────────── LLM provider keys (n8n agent chat models) ────────────────
# Bring-your-own (answers.env). Each key you supply is injected into the
# matching n8n credential at import, so that provider's Chat Model node works
# on a fresh deploy. Azure OpenAI is the default model wired to every agent;
# empty keys just leave that provider's node unconfigured on the canvas.
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
# Azure endpoint + deployment name that back the default Azure model on every agent.
# Both are bring-your-own (answers.env); leave blank to leave the Azure node unconfigured.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Model the code-first agent example (integrations/code-agent) uses:
ANTHROPIC_MODEL=claude-opus-4-8

# ──────────────── Observability: Langfuse (self-hosted tracing) ────────────────
# All generated + persisted by bootstrap_secrets.py. The pk-lf/sk-lf pair lets
# Langfuse headless-init bootstrap the project so Langflow traces work with no UI
# step; NEXTAUTH_SECRET/SALT/LANGFUSE_ENCRYPTION_KEY are standard secrets.
NEXTAUTH_SECRET=generated-at-install
SALT=generated-at-install
LANGFUSE_ENCRYPTION_KEY=generated-at-install
LANGFUSE_PUBLIC_KEY=generated-at-install
LANGFUSE_SECRET_KEY=generated-at-install
# Leave blank — the compose langfuse service builds the URL from POSTGRES_*:
LANGFUSE_DATABASE_URL=
LANGFUSE_TELEMETRY_ENABLED=false
# LiteLLM proxy master key (n8n + Langflow -> Langfuse tracing path). Generated
# by bootstrap_secrets.py; the n8n OpenAI/Azure credentials and every Langflow
# flow authenticate to the internal litellm service with it.
LITELLM_MASTER_KEY=generated-at-install

# ──────────────── Integration credentials (set once, auto-injected) ────────────────
# Injected into the matching n8n credential on every deploy (answers.env values
# land here via bootstrap). Lakera = external SaaS key (platform.lakera.ai).
# SCIM token must match the token configured in the Identity Provider (IdP) simulator.
LAKERA_API_KEY=
LAKERA_PROJECT_ID=
IDP_SCIM_TOKEN=
QDRANT_API_KEY=

# n8n External URLs (for Traefik routing)
WEBHOOK_URL=https://n8n.{{DOMAIN}}/
N8N_EDITOR_BASE_URL=https://n8n.{{DOMAIN}}/
N8N_PUSH_BACKEND=websocket

# ──────────────── Ollama (Local LLM) ────────────────
OLLAMA_PORT=11434
OLLAMA_HOST=http://ollama-cpu:11434
OLLAMA_KEEP_ALIVE=-1
# RAM guard on CPU boxes: at most N models resident at once.
OLLAMA_MAX_LOADED_MODELS=2
# Models pulled on startup (comma-separated). Only gemma4:e2b is pulled by
# default — each extra model is several GB and a small root disk fills fast
# (a full pull list crashed Dokploy by filling the disk). To re-enable the full
# set, comment out the active line below and uncomment the full one.
#   gemma4:e2b            → Open WebUI chat default (small/fast) — DEFAULT
#   qwen3.5:9b            → n8n agents (best tool-call reliability, official build)
#   mythos-9b-unhinged    → AI Guardrails attack target (uncensored — makes Guard visible)
#   deepseek-r1:8b        → reasoning demo (chat only, not agents)
#   qwen3-embedding:0.6b  → RAG / Qdrant embeddings
# OLLAMA_MODELS=gemma4:e2b,qwen3.5:9b,richardyoung/mythos-9b-unhinged-abliterated:latest,huihui_ai/deepseek-r1-abliterated:8b,qwen3-embedding:0.6b
# CPU-only default: fast chat model + the best LIGHT tool-calling model
OLLAMA_MODELS=gemma4:e2b,qwen3.5:4b,nomic-embed-text

# ──────────────── Open WebUI Configuration ────────────────
# OLLAMA_BASE_URL tells Open WebUI where to find Ollama (required)
OLLAMA_BASE_URL=http://ollama-cpu:11434
OPEN_WEBUI_ADMIN_EMAIL=admin@{{DOMAIN}}
OPEN_WEBUI_ADMIN_PASSWORD=your-secure-password
OPEN_WEBUI_DEFAULT_MODELS=gemma4:e2b

# ──────────────── AI Services Ports ────────────────
LANGFLOW_PORT=7860
FLOWISE_PORT=3020
OPEN_WEBUI_PORT=8090
QDRANT_PORT=6333

# ──────────────── Check Point MCP Credentials [OPTIONAL] ────────────────
# Documentation MCP
DOC_CLIENT_ID=your-doc-client-id
DOC_SECRET_KEY=your-doc-secret-key
DOC_REGION=EU

# SMS MCP
MANAGEMENT_HOST=
MANAGEMENT_API_KEY=
SMS_API_KEY=
TE_API_KEY=your-te-api-key
REPUTATION_API_KEY=your-reputation-api-key

# Gaia OS agent — a reachable gateway + its Gaia login. Upstream the Gaia MCP server
# prompts for these via an interactive browser dialog that can't run headless; setting
# them here is the env-credential fallback so the Gaia agent works at deploy. Leave blank
# to keep the Gaia tools inert. Host may be IP or hostname; port defaults to 443.
GAIA_GATEWAY_IP=
GAIA_GATEWAY_PORT=443
GAIA_USERNAME=
GAIA_PASSWORD=

# Spark Management
SPARK_MGMT_CLIENT_ID=your-spark-client-id
SPARK_MGMT_SECRET_KEY=your-spark-secret-key
SPARK_MGMT_REGION=US
SPARK_MGMT_INFINITY_PORTAL_URL=https://cloudinfra-gw-us.portal.checkpoint.com/auth/external

# Harmony SASE
HARMONY_SASE_API_KEY=
HARMONY_SASE_MANAGEMENT_HOST=
HARMONY_SASE_REGION=

# IPS MCP — Infinity Portal IPS service. Bring-your-own (answers.env); leave blank
# to keep the IPS tools inert. AUTH/SERVICE URLs are the Infinity Portal endpoints.
IPS_CLIENT_ID=
IPS_ACCESS_KEY=
IPS_AUTH_URL=
IPS_SERVICE_URL=

# Logging
CPINFO_LOG_LEVEL=info

# ──────────────── Optional Services ────────────────
# Profile(s), comma-separated: cpu (default) or gpu; add security-lab to enable the
# security-lab services. Override from answers.env (e.g. COMPOSE_PROFILES=cpu,security-lab).
COMPOSE_PROFILES=cpu

# Enable/Disable services
DEPLOY_FLOWISE=true
DEPLOY_LANGFLOW=true
DEPLOY_VLLM=false

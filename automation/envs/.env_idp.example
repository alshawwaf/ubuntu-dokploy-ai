# ============================================================================
# Identity Provider (IdP) - Environment Configuration
# ============================================================================
# saml-idp-compose.yml consumes these via ${VAR:-default}. Supplying them here
# (generated by bootstrap_secrets.py) overrides the weak in-repo defaults.
# ============================================================================

IDP_ADMIN_PASSWORD=changeme
IDP_SECRET_KEY=changeme

# SCIM provisioning (auto-seeded inbound bearer token; shared with the SCIM agent)
ENABLE_SCIM=true
IDP_SCIM_TOKEN=generated-at-install
